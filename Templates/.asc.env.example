# App Store Connect API credentials — used by Scripts/*.sh, Scripts/*.rb, and
# the Fastfile helper `load_asc_env`.
#
# Copy this file to Scripts/.asc.env and fill in your values. The real
# .asc.env is gitignored — never commit it.
#
#   cp Templates/.asc.env.example Scripts/.asc.env
#
# Where to find these:
#   App Store Connect -> Users and Access -> Integrations -> App Store Connect API
#     ASC_ISSUER_ID : the "Issuer ID" UUID at the top of that page
#     ASC_KEY_ID    : the "Key ID" column for the key you created
#     ASC_KEY_PATH  : absolute path to the AuthKey_<KEY_ID>.p8 you downloaded
#                     (one-time download — save it somewhere outside the repo)

ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_PATH=

# --- Optional: your app identity ---------------------------------------------
# Every AscKit script and lane reads these too. You can set them here or
# export them in your shell / CI env — env vars win over this file.

# ASC_BUNDLE_ID=com.example.MyApp
# ASC_TEAM_ID=TEAMID1234
# ASC_XCODE_PROJECT=MyApp.xcodeproj
# ASC_XCODE_SCHEME=MyApp
# SCREENSHOT_LOCALE=en-US

# --- Optional: IAP (only for Scripts/setup-iap.rb & friends) -----------------
# IAP_PRODUCT_ID=com.example.MyApp.pro.fullaccess
# IAP_REF_NAME=Pro Full Access
# IAP_DISPLAY_NAME=Pro — Full Access
# IAP_DESCRIPTION=Unlock all premium features.
# IAP_PRICE=4.99
# IAP_PRICE_TERRITORY=USA
# IAP_LOCALE=en-US
# IAP_SCREENSHOT=/absolute/path/to/paywall.png
