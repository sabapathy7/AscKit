# frozen_string_literal: true
#
# AscKit — App Store Connect release template
# https://github.com/sabapathy7/AscKit
#
# Copy this file to fastlane/Fastfile in your app repo and adjust the CONFIG
# block below (or export the equivalent ASC_* environment variables). Every
# lane here uses App Store Connect API key auth (ASC_KEY_ID / ASC_ISSUER_ID /
# ASC_KEY_PATH), loaded from Scripts/.asc.env if not already set in the
# environment.
#
# Lanes provided:
#   fastlane beta                — archive + upload to TestFlight (no submit)
#   fastlane upload_screenshots  — deliver screenshots only (no binary/metadata)
#   fastlane stage_screenshots   — dry-run screenshot staging (no upload)

default_platform(:ios)

# ---------------------------------------------------------------------------
# Configuration — override any of these via ENV.
# ---------------------------------------------------------------------------

# App identity — required. In CI, set these in the workflow env; locally they
# can be exported in your shell or left as literal values here.
APP_IDENTIFIER = ENV.fetch("ASC_BUNDLE_ID", "com.example.MyApp").freeze
TEAM_ID        = ENV.fetch("ASC_TEAM_ID",   "TEAMID1234").freeze

# Xcode project — either a .xcodeproj (default) or set ASC_WORKSPACE for a
# .xcworkspace-based project.
PROJECT        = ENV.fetch("ASC_XCODE_PROJECT", "MyApp.xcodeproj").freeze
WORKSPACE      = ENV["ASC_XCODE_WORKSPACE"]
SCHEME         = ENV.fetch("ASC_XCODE_SCHEME",  "MyApp").freeze

# Output binary name (used for gym output_name)
OUTPUT_NAME    = ENV.fetch("ASC_OUTPUT_NAME", SCHEME).freeze

# App Store Connect listing locale for screenshot uploads. Must match ASC
# exactly (case sensitive) e.g. en-GB, en-US, fr-FR.
SCREENSHOT_LOCALE = ENV.fetch("SCREENSHOT_LOCALE", "en-US").freeze

# Where to find prepared screenshots on disk. deliver picks the target device
# slot by pixel dimensions, so both iPhone and iPad PNGs are copied into the
# same fastlane/screenshots/<locale>/ folder before upload.
IPHONE_SRC = ENV.fetch(
  "IPHONE_SCREENSHOTS",
  File.expand_path("../screenshots-src/iphone", __dir__)
).freeze

IPAD_SRC = ENV.fetch(
  "IPAD_SCREENSHOTS",
  File.expand_path("../screenshots-src/ipad", __dir__)
).freeze

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Load ASC API credentials from Scripts/.asc.env if not already exported.
# CI should inject ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_PATH (or ASC_KEY_CONTENT)
# as secrets rather than committing a .asc.env file.
def load_asc_env
  return if ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && (ENV["ASC_KEY_PATH"] || ENV["ASC_KEY_CONTENT"])

  env_path = File.expand_path("../Scripts/.asc.env", __dir__)
  unless File.exist?(env_path)
    UI.important("No Scripts/.asc.env — expecting ASC_* env vars from CI secrets.")
    return
  end

  File.foreach(env_path) do |line|
    line = line.strip
    next if line.empty? || line.start_with?("#")

    key, _, value = line.partition("=")
    next if key.empty?

    ENV[key.strip] ||= value.strip
  end
end

def asc_api_key
  load_asc_env

  key_id    = ENV.fetch("ASC_KEY_ID")
  issuer_id = ENV.fetch("ASC_ISSUER_ID")

  if ENV["ASC_KEY_CONTENT"] && !ENV["ASC_KEY_CONTENT"].empty?
    return app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: ENV["ASC_KEY_CONTENT_BASE64"] == "true",
      in_house: false
    )
  end

  key_path = ENV.fetch("ASC_KEY_PATH")
  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_filepath: key_path,
    in_house: false
  )
end

# Copy PNGs from IPHONE_SRC and IPAD_SRC into fastlane/screenshots/<locale>/
# with a device prefix. deliver classifies each PNG by its pixel dimensions,
# so flat/renamed files are fine as long as the images themselves are the
# correct App Store size.
def assemble_screenshots
  require "fileutils"

  dest = File.expand_path("screenshots/#{SCREENSHOT_LOCALE}", __dir__)
  FileUtils.rm_rf(dest)
  FileUtils.mkdir_p(dest)

  copied = 0

  [["iphone", IPHONE_SRC], ["ipad", IPAD_SRC]].each do |label, src|
    unless Dir.exist?(src)
      UI.important("Skipping #{label}: source folder not found -> #{src}")
      next
    end

    pngs = Dir.glob(File.join(src, "*.png")).sort
    if pngs.empty?
      UI.important("Skipping #{label}: no PNGs in #{src}")
      next
    end

    pngs.each do |png|
      FileUtils.cp(png, File.join(dest, "#{label}-#{File.basename(png)}"))
      copied += 1
    end
    UI.message("Staged #{pngs.length} #{label} screenshot(s) from #{src}")
  end

  UI.user_error!("No screenshots were staged. Check IPHONE_SCREENSHOTS / IPAD_SCREENSHOTS paths.") if copied.zero?
  UI.success("Staged #{copied} screenshot(s) into #{dest}")
end

# Optional Slack / webhook notify — no-op if SLACK_URL / SLACK_WEBHOOK_URL is unset.
def notify_release!(message:)
  slack_url = ENV["SLACK_URL"] || ENV["SLACK_WEBHOOK_URL"]
  if slack_url.to_s.empty?
    UI.success(message)
    return
  end

  slack(
    slack_url: slack_url,
    message: message,
    success: true,
    default_payloads: %i[git_branch git_author last_git_commit]
  )
rescue StandardError => e
  UI.important("Notify failed (non-fatal): #{e.message}")
end

# Common gym/build_app parameters. WORKSPACE takes precedence over PROJECT if set.
def build_params
  params = {
    scheme: SCHEME,
    configuration: "Release",
    clean: true,
    destination: "generic/platform=iOS",
    export_method: "app-store",
    export_options: {
      method: "app-store-connect",
      teamID: TEAM_ID,
      signingStyle: "automatic",
      uploadSymbols: true,
      manageAppVersionAndBuildNumber: false
    },
    output_directory: "build/fastlane",
    output_name: OUTPUT_NAME,
    xcargs: "CODE_SIGN_STYLE=Automatic DEVELOPMENT_TEAM=#{TEAM_ID} -allowProvisioningUpdates"
  }
  if WORKSPACE
    params[:workspace] = WORKSPACE
  else
    params[:project] = PROJECT
  end
  params
end

# ---------------------------------------------------------------------------
# Lanes
# ---------------------------------------------------------------------------
platform :ios do
  desc "Build, upload to TestFlight, and notify (does NOT submit for App Review)"
  lane :beta do
    api_key = asc_api_key

    # Optional: bump the build number in CI. Skip if you manage it in Xcode.
    if ENV["BUILD_NUMBER"]
      increment_build_number(
        build_number: ENV["BUILD_NUMBER"],
        xcodeproj: PROJECT
      )
    end

    build_app(**build_params)

    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false,
      changelog: ENV.fetch(
        "TESTFLIGHT_CHANGELOG",
        "CI build from #{ENV['GITHUB_SHA'] || ENV['GIT_COMMIT'] || 'local'}"
      )
    )

    version = get_version_number(xcodeproj: PROJECT, target: SCHEME) rescue nil
    build   = get_build_number(xcodeproj: PROJECT) rescue nil
    notify_release!(message: "TestFlight upload complete (#{APP_IDENTIFIER} #{version} build #{build})")
  end

  desc "Upload App Store screenshots only (no binary, no metadata)"
  lane :upload_screenshots do
    api_key = asc_api_key
    assemble_screenshots

    deliver(
      api_key: api_key,
      app_identifier: APP_IDENTIFIER,
      screenshots_path: File.expand_path("screenshots", __dir__),
      skip_binary_upload: true,
      skip_metadata: true,
      skip_app_version_update: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      submit_for_review: false,
      force: true
    )

    notify_release!(message: "App Store screenshots uploaded (#{APP_IDENTIFIER}, #{SCREENSHOT_LOCALE})")
  end

  desc "Stage screenshots locally without uploading (dry run)"
  lane :stage_screenshots do
    assemble_screenshots
    UI.success("Dry run complete. Review fastlane/screenshots/#{SCREENSHOT_LOCALE} then run: fastlane upload_screenshots")
  end
end
